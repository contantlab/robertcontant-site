# Cloudflare Pages — security & cache headers for robertcontant.com
#
# CSP note: the placeholder token in `script-src` below is rewritten at build
# time by scripts/inject-csp-hashes.mjs (chained after `astro build`) into the
# SHA-256 source-expressions of every inline <script> Astro emits, so we can
# keep 'unsafe-inline' OUT of script-src. New inline scripts are picked up
# automatically on the next build.

/*
  Content-Security-Policy: default-src 'self'; script-src 'self' {{SCRIPT_HASHES}}; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://formspree.io; form-action 'self' https://formspree.io; frame-ancestors 'none'; frame-src 'none'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=(), screen-wake-lock=(), xr-spatial-tracking=()
  Cross-Origin-Opener-Policy: same-origin

# Hashed assets — safe to cache aggressively (Astro fingerprints filenames)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts — content-addressed by name; never change without a new name
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

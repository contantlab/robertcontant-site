# Cloudflare - security & cache headers for robertcontant.com
#
# CSP note: the SHA-256 hashes in `script-src` correspond exactly to the
# inline <script> blocks Astro emits (theme-init, theme-toggle, contact-form).
# If you edit any of those scripts, the hashes drift and the post-build
# verifier (scripts/inject-csp-hashes.mjs) will fail the build with a clear
# diff so you know to re-sync. Re-sync with: `npm run headers:sync`.

/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-9sfm2ij/WN87RZaLBDlMfMP2DSjjlrhH4FDWVpBqKZY=' 'sha256-dGzXjF8VMYUOBKM5wJqYg1Tg9T2QvRmkZ7Nt7QaTq7I=' 'sha256-jH3FXEYqrIQ7WU0Gw4JiPW3fGi3fjDF3p3dgPxA6B0Q='; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://formspree.io; form-action 'self' https://formspree.io; frame-ancestors 'none'; frame-src 'none'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=(), screen-wake-lock=(), xr-spatial-tracking=()
  Cross-Origin-Opener-Policy: same-origin

# Hashed assets - safe to cache aggressively (Astro fingerprints filenames)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts - content-addressed by name; never change without a new name
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

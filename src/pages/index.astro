---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate, isoDate } from '../lib/format';
import { SITE } from '../config/site';

const isProd = import.meta.env.PROD;
const featured = (
  await getCollection('projects', ({ data }) => data.featured && (isProd ? !data.draft : true))
).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const capabilities = [
  {
    label: 'Security Engineering',
    detail: 'Hardening M365 & Azure, identity and access, detection and response, vulnerability management.',
  },
  {
    label: 'Security Operations & IR',
    detail: 'SOC oversight, incident response, threat investigation, security monitoring.',
  },
  {
    label: 'GRC Foundation',
    detail: 'ISO 27001, SOC 1/2, ISAE 3402, GDPR, NIS 2, audit readiness, vendor risk.',
  },
  {
    label: 'Build & Automate',
    detail: 'Python, AI-powered workflows, OSINT tooling, self-hosted infrastructure.',
  },
];
---

<BaseLayout>
  <section class="hero page-shell">
    <p class="eyebrow">Cybersecurity Engineer &middot; Builder</p>
    <h1 class="hero-headline">
      I secure systems, investigate risk, and build tools that make security work.
    </h1>
    <p class="hero-lede">
      I&rsquo;m Bobby Contant - a cybersecurity and information assurance professional
      moving deeper into hands-on security engineering. I work across cloud security,
      identity, detection and response, OSINT, and AI-powered automation, with a
      foundation in ISO&nbsp;27001, SOC&nbsp;2, and GDPR. I like making security practical:
      hardening real systems, cutting manual work, and turning scattered tools and
      tickets into something that actually works.
    </p>
    <div class="hero-cta">
      <a href="/projects/" class="cta-link cta-primary">View Projects</a>
      <a href="/blog/" class="cta-link cta-primary">Read the Blog</a>
    </div>
    <div class="hero-cta-secondary">
      <a href={SITE.github} rel="me noopener" target="_blank">GitHub</a>
      <span class="dot" aria-hidden="true">&middot;</span>
      <a href={SITE.linkedin} rel="me noopener" target="_blank">LinkedIn</a>
      <span class="dot" aria-hidden="true">&middot;</span>
      <a href="/resume/">Resume</a>
    </div>
  </section>

  <section class="capabilities page-shell" aria-labelledby="what-i-do">
    <header class="strip-header">
      <h2 id="what-i-do" class="strip-title">What I do</h2>
      <a href="/about/" class="strip-link">More about me &rarr;</a>
    </header>
    <ul class="capability-grid">
      {capabilities.map((c) => (
        <li class="capability">
          <h3 class="capability-label">{c.label}</h3>
          <p class="capability-detail">{c.detail}</p>
        </li>
      ))}
    </ul>
  </section>

  <section class="featured page-shell" aria-labelledby="featured-heading">
    <header class="strip-header">
      <h2 id="featured-heading" class="strip-title">Selected work</h2>
      <a href="/projects/" class="strip-link">All projects &rarr;</a>
    </header>

    {featured.length === 0 ? (
      <p class="empty">No featured projects yet.</p>
    ) : (
      <ol class="featured-list" aria-label="Featured projects">
        {featured.map((p, i) => (
          <li class="featured-item">
            <a href={`/projects/${p.id}/`} class="featured-link">
              <span class="featured-n">{String(i + 1).padStart(2, '0')}</span>
              <div class="featured-body">
                <h3 class="featured-title">{p.data.title}</h3>
                <p class="featured-summary">{p.data.summary}</p>
                {p.data.stack.length > 0 && (
                  <p class="featured-stack"><code>{p.data.stack.join(' · ')}</code></p>
                )}
              </div>
              <time class="featured-date" datetime={isoDate(p.data.date)}>{formatDate(p.data.date)}</time>
            </a>
          </li>
        ))}
      </ol>
    )}
  </section>
</BaseLayout>

<style>
  /* hero */
  .hero {
    /* match page-shell container width so the section aligns with the
       capability + featured strips below; tighter top padding so the eyebrow
       sits closer to the header */
    padding-block: var(--space-10) var(--space-10);
  }
  .hero .eyebrow { margin-bottom: var(--space-4); }
  .hero-headline {
    /* Long-form sentence headline - pull the size down from the global h1
       display scale (44–76px) so it doesn't dominate. Cap line length so it
       wraps to 2–3 lines on desktop instead of one sprawling row. */
    font-size: var(--text-4xl);
    max-width: 26ch;
    margin-bottom: var(--space-5);
  }
  .hero-lede {
    font-size: var(--text-lg);
    color: var(--color-ink-muted);
    max-width: var(--measure);
    margin-bottom: var(--space-8);
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4) var(--space-5);
    align-items: center;
  }
  .cta-link {
    font-size: var(--text-sm);
    text-decoration: none;
    color: var(--color-ink);
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-rule-strong);
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }
  .cta-link::after {
    content: ' \2192';
    color: var(--color-ink-subtle);
    transition: transform var(--transition-fast), color var(--transition-fast);
    display: inline-block;
  }
  .cta-link:hover { color: var(--color-accent); border-bottom-color: var(--color-accent); }
  .cta-link:hover::after { color: var(--color-accent); transform: translateX(2px); }
  .cta-primary { color: var(--color-accent); border-bottom-color: var(--color-accent); font-weight: 600; }

  .hero-cta-secondary {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-5);
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
  }
  .hero-cta-secondary a {
    color: var(--color-ink-muted);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-block: 2px;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }
  .hero-cta-secondary a:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  .hero-cta-secondary .dot { color: var(--color-ink-subtle); }

  /* shared strip header (used by capabilities + featured) */
  .strip-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-5);
    margin-bottom: var(--space-8);
  }
  .strip-title { font-size: var(--text-2xl); }
  .strip-link {
    font-size: var(--text-sm);
    text-decoration: none;
    color: var(--color-ink-muted);
  }
  .strip-link:hover { color: var(--color-accent); }

  /* capabilities */
  .capabilities {
    padding-block: var(--space-10);
    border-top: 1px solid var(--color-rule);
  }
  .capability-grid {
    list-style: none;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-6) var(--space-8);
  }
  .capability { max-width: 36ch; }
  .capability-label {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 600;
    letter-spacing: 0;
    color: var(--color-ink);
    margin-bottom: var(--space-2);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-rule);
  }
  .capability-detail {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    line-height: var(--leading-base);
  }

  /* featured */
  .featured {
    padding-block: var(--space-10);
    border-top: 1px solid var(--color-rule);
  }
  .empty { color: var(--color-ink-muted); font-style: italic; }

  .featured-list {
    list-style: none;
    margin: 0;
    display: grid;
    gap: 0;
  }
  .featured-item { border-top: 1px solid var(--color-rule); }
  .featured-item:last-child { border-bottom: 1px solid var(--color-rule); }

  .featured-link {
    display: grid;
    grid-template-columns: 3rem 1fr auto;
    gap: var(--space-5);
    align-items: baseline;
    padding-block: var(--space-5);
    text-decoration: none;
    color: var(--color-ink);
    transition: background var(--transition-fast);
  }
  .featured-link:hover {
    background: color-mix(in oklab, var(--color-accent-soft) 60%, transparent);
  }

  .featured-n {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-ink-subtle);
  }

  .featured-body { max-width: var(--measure); }

  .featured-title {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 500;
    margin-bottom: var(--space-2);
    color: var(--color-ink);
  }
  .featured-link:hover .featured-title { color: var(--color-accent); }

  .featured-summary {
    color: var(--color-ink-muted);
    font-size: var(--text-base);
    margin-bottom: var(--space-2);
  }

  .featured-stack code {
    background: var(--color-code-bg);
    color: var(--color-ink-muted);
    padding: 1px 8px;
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
  }

  .featured-date {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-ink-subtle);
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .featured-link { grid-template-columns: 2rem 1fr; }
    .featured-date { grid-column: 2; }
  }
</style>

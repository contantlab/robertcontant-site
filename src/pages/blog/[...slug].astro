---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { formatDate, isoDate, readingTime } from '../../lib/format';

export async function getStaticPaths() {
  const isProd = import.meta.env.PROD;
  const entries = await getCollection('blog', ({ data }) => (isProd ? !data.draft : true));
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const rt = readingTime(entry.body ?? '');
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  noindex={entry.data.draft}
>
  <article class="post page-shell">
    <header class="post-head">
      <p class="eyebrow"><a href="/blog/">Blog</a></p>
      <h1>{entry.data.title}</h1>
      <p class="post-meta">
        <time datetime={isoDate(entry.data.date)}>{formatDate(entry.data.date)}</time>
        <span class="dot" aria-hidden="true">·</span>
        <span>{rt.label}</span>
        {entry.data.tags.length > 0 && (
          <>
            <span class="dot" aria-hidden="true">·</span>
            <span class="post-tags">{entry.data.tags.join(', ')}</span>
          </>
        )}
      </p>
    </header>

    <div class="prose post-body">
      <Content />
    </div>

    <footer class="post-foot">
      <a class="back-link" href="/blog/">&larr; All posts</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .post {
    padding-block: clamp(var(--space-10), 10vw, var(--space-12)) var(--space-10);
    max-width: 44rem;
  }

  .post-head { margin-bottom: var(--space-10); }
  .post-head .eyebrow { margin-bottom: var(--space-4); }
  .post-head .eyebrow a {
    color: var(--color-ink-muted);
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }
  .post-head .eyebrow a:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .post-head h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }

  .post-meta {
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
    display: inline-flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }

  .post-meta .dot { color: var(--color-ink-subtle); }

  .post-tags { font-family: var(--font-mono); font-size: 0.92em; }

  .post-body :global(p),
  .post-body :global(ul),
  .post-body :global(ol),
  .post-body :global(blockquote) {
    margin-block: var(--space-4);
  }
  .post-body :global(h2) {
    font-size: var(--text-2xl);
    margin-block: var(--space-8) var(--space-3);
  }
  .post-body :global(h3) {
    font-size: var(--text-xl);
    margin-block: var(--space-6) var(--space-2);
  }
  .post-body :global(blockquote) {
    border-left: 2px solid var(--color-rule-strong);
    padding-left: var(--space-4);
    color: var(--color-ink-muted);
    font-style: italic;
  }
  .post-body :global(ul), .post-body :global(ol) { padding-left: var(--space-5); }
  .post-body :global(li) { margin-block: var(--space-2); }
  .post-body :global(pre) { margin-block: var(--space-5); }
  .post-body :global(img) { border-radius: var(--radius); margin-block: var(--space-5); }

  .post-foot {
    margin-top: var(--space-10);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-rule);
  }

  .back-link {
    color: var(--color-ink-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule-strong);
    padding-bottom: 2px;
  }
  .back-link:hover { color: var(--color-accent); border-color: var(--color-accent); }
</style>

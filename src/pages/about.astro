---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Content as AboutContent } from '../content/pages/about.mdx';

const skills = [
  {
    label: 'Cloud & Platform Security',
    items: ['Microsoft 365', 'Azure', 'Entra ID', 'identity & access management', 'endpoint protection'],
  },
  {
    label: 'Security Operations',
    items: ['detection & response', 'SIEM', 'security monitoring', 'incident response', 'threat investigation', 'SOC oversight'],
  },
  {
    label: 'Vulnerability & Risk',
    items: ['vulnerability management', 'penetration test coordination', 'vendor risk', 'risk tracking'],
  },
  {
    label: 'GRC',
    items: ['ISO 27001', 'SOC 1/2', 'ISAE 3402', 'GDPR', 'NIS 2', 'audit readiness', 'policy development', 'user access reviews'],
  },
  {
    label: 'Build & Automate',
    items: ['Python', 'Django', 'Streamlit', 'AI agents & workflows', 'OSINT tooling'],
  },
  {
    label: 'Infrastructure',
    items: ['home lab', 'self-hosted & privacy-focused systems', 'local-first architecture'],
  },
];
---

<BaseLayout
  title="About"
  description="Robert Contant - cybersecurity engineer focused on hands-on security engineering, security operations, GRC, and AI-powered automation."
>
  <section class="about page-shell">
    <header class="about-head">
      <p class="eyebrow">About</p>
      <h1>About me.</h1>
    </header>

    <div class="prose about-body">
      <AboutContent />
    </div>

    <section class="about-skills" aria-labelledby="skills-heading">
      <h2 id="skills-heading">Skills</h2>
      <dl class="skill-list">
        {skills.map((s) => (
          <div class="skill-row">
            <dt>{s.label}</dt>
            <dd>{s.items.join(' · ')}</dd>
          </div>
        ))}
      </dl>
    </section>
  </section>
</BaseLayout>

<style>
  .about {
    /* Centered column that's wider than a strict prose measure but not the
       full page-shell. Paragraphs below drop their own max-width so they fill
       this container - eliminates the inner empty space on the right while
       keeping symmetric padding on both sides of the section. */
    padding-block: var(--space-10) var(--space-10);
    max-width: 60rem;
  }

  .about-head { margin-bottom: var(--space-10); }
  .about-head .eyebrow { margin-bottom: var(--space-4); }
  .about-head h1 {
    font-size: var(--text-4xl);
  }

  .about-body :global(h2) {
    font-size: var(--text-2xl);
    margin-block: var(--space-8) var(--space-3);
  }
  .about-body :global(h3) {
    font-size: var(--text-xl);
    margin-block: var(--space-6) var(--space-2);
  }
  .about-body :global(p),
  .about-body :global(ul),
  .about-body :global(ol),
  .about-body :global(blockquote) {
    margin-block: var(--space-4);
  }
  .about-body :global(blockquote) {
    border-left: 2px solid var(--color-rule-strong);
    padding-left: var(--space-4);
    color: var(--color-ink-muted);
    font-style: italic;
  }
  .about-body :global(ul), .about-body :global(ol) { padding-left: var(--space-5); }
  .about-body :global(li) { margin-block: var(--space-2); }
  .about-body :global(li) :global(strong) { color: var(--color-ink); }

  /* skills strip - mirrors the resume page so the site feels coherent */
  .about-skills {
    margin-top: var(--space-10);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-rule);
  }
  .about-skills h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-5);
  }
  .skill-list { margin: 0; display: grid; gap: 0; }
  .skill-row {
    display: grid;
    grid-template-columns: 14rem 1fr;
    gap: var(--space-5);
    align-items: baseline;
    padding-block: var(--space-3);
    border-bottom: 1px solid var(--color-rule);
  }
  .skill-row:last-child { border-bottom: 0; }
  .skill-row dt {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }
  .skill-row dd {
    margin: 0;
    color: var(--color-ink);
    font-size: var(--text-sm);
  }
  @media (max-width: 640px) {
    .skill-row { grid-template-columns: 1fr; gap: var(--space-2); }
  }
</style>

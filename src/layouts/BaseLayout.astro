---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../config/site';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  /** Add `noindex,nofollow` (e.g. for drafts) */
  noindex?: boolean;
}

const {
  title,
  description = SITE.description,
  ogImage = SITE.defaultOgImage,
  noindex = false,
} = Astro.props;

const pageTitle = title ? `${title} — ${SITE.title}` : `${SITE.title} — ${SITE.tagline}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE.url).toString();
const ogImageAbs = new URL(ogImage, Astro.site ?? SITE.url).toString();

const personJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.author,
  url: SITE.url,
  jobTitle: SITE.tagline,
  sameAs: [SITE.github, SITE.linkedin],
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={SITE.locale} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <link rel="preload" href="/fonts/InterVariable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/SourceSerif4Variable-Roman.woff2" as="font" type="font/woff2" crossorigin />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />

    <script type="application/ld+json" set:html={personJsonLd} />

    {/* Inline theme setup to avoid FOUC: runs before <body> paints */}
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t === 'light' || t === 'dark') {
            document.documentElement.dataset.theme = t;
          }
        } catch (_) {}
      })();
    </script>
  </head>

  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <style>
      .skip-link {
        position: absolute;
        left: var(--space-4);
        top: var(--space-3);
        background: var(--color-bg-elevated);
        color: var(--color-ink);
        padding: var(--space-2) var(--space-4);
        border-radius: var(--radius-sm);
        border: 1px solid var(--color-rule-strong);
        text-decoration: none;
        transform: translateY(-200%);
        transition: transform var(--transition);
        z-index: 100;
      }
      .skip-link:focus { transform: translateY(0); }
    </style>
  </body>
</html>

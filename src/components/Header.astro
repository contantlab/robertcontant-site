---
import { NAV, SITE } from '../config/site';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="site-header">
  <div class="page-shell header-inner">
    <a href="/" class="brand" aria-label={`${SITE.title} — home`}>
      <span class="brand-name">{SITE.title}</span>
      <span class="brand-dot" aria-hidden="true"></span>
      <span class="brand-tag">{SITE.tagline}</span>
    </a>

    <nav aria-label="Primary">
      <ul class="nav-list">
        {NAV.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={['nav-link', { 'is-active': isActive(href) }]}
              aria-current={isActive(href) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <button
      id="theme-toggle"
      class="theme-toggle"
      type="button"
      aria-label="Toggle color theme"
      title="Toggle color theme"
    >
      <svg class="theme-icon theme-icon-sun" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
        <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.6" />
        <g stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
          <line x1="12" y1="2.5" x2="12" y2="5" />
          <line x1="12" y1="19" x2="12" y2="21.5" />
          <line x1="2.5" y1="12" x2="5" y2="12" />
          <line x1="19" y1="12" x2="21.5" y2="12" />
          <line x1="5.2" y1="5.2" x2="6.9" y2="6.9" />
          <line x1="17.1" y1="17.1" x2="18.8" y2="18.8" />
          <line x1="5.2" y1="18.8" x2="6.9" y2="17.1" />
          <line x1="17.1" y1="6.9" x2="18.8" y2="5.2" />
        </g>
      </svg>
      <svg class="theme-icon theme-icon-moon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
        <path
          d="M20.5 14.2A8 8 0 0 1 9.8 3.5a8 8 0 1 0 10.7 10.7z"
          fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"
        />
      </svg>
    </button>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-rule);
    background: color-mix(in oklab, var(--color-bg) 88%, transparent);
    backdrop-filter: saturate(160%) blur(8px);
    -webkit-backdrop-filter: saturate(160%) blur(8px);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    min-height: 64px;
    padding-block: var(--space-3);
  }

  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--color-ink);
    margin-inline-end: auto;
  }

  .brand-name {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 500;
    letter-spacing: var(--tracking-tight);
  }

  .brand-dot {
    width: 4px; height: 4px;
    border-radius: 50%;
    background: var(--color-accent);
    align-self: center;
    flex-shrink: 0;
  }

  .brand-tag {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    letter-spacing: var(--tracking-wide);
  }

  @media (max-width: 640px) {
    .brand-tag, .brand-dot { display: none; }
  }

  .nav-list {
    list-style: none;
    margin: 0;
    display: flex;
    gap: var(--space-5);
    align-items: center;
  }

  .nav-link {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    text-decoration: none;
    padding-block: 4px;
    border-bottom: 1px solid transparent;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-ink);
    border-bottom-color: var(--color-rule-strong);
  }

  .nav-link.is-active {
    color: var(--color-ink);
    border-bottom-color: var(--color-accent);
  }

  @media (max-width: 540px) {
    .nav-list { gap: var(--space-4); }
    .nav-link { font-size: var(--text-xs); }
  }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px; height: 36px;
    border-radius: var(--radius-sm);
    color: var(--color-ink-muted);
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .theme-toggle:hover {
    color: var(--color-ink);
    background: var(--color-code-bg);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .theme-icon { display: none; }
  :global(:root[data-theme='light']) .theme-icon-moon { display: block; }
  :global(:root[data-theme='dark'])  .theme-icon-sun  { display: block; }
  /* fallback: no explicit theme set — use system preference */
  @media (prefers-color-scheme: light) {
    :global(:root:not([data-theme])) .theme-icon-moon { display: block; }
  }
  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme])) .theme-icon-sun  { display: block; }
  }
</style>

<script>
  const btn = document.getElementById('theme-toggle');
  const root = document.documentElement;
  btn?.addEventListener('click', () => {
    const current =
      root.dataset.theme ??
      (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    const next = current === 'dark' ? 'light' : 'dark';
    root.dataset.theme = next;
    try { localStorage.setItem('theme', next); } catch {}
  });
</script>
